# =============================================================
#  KANBAN PRO — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  cp .env.example .env
# =============================================================

# ─── DATABASE ─────────────────────────────────────────────────
# Prisma connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:change_me@localhost:5432/kanban_db?schema=public"

# ─── SERVER ───────────────────────────────────────────────────
# Port the Express API will listen on
PORT=3001

# Node environment: development | production | test
NODE_ENV=development

# ─── AUTH ─────────────────────────────────────────────────────
# Secret key for signing JWT tokens — use a long random string in production
# Generate one: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret

# Token expiry duration (e.g. 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
# Allowed origin for cross-origin requests (your frontend URL)
CORS_ORIGIN=http://localhost:3000
