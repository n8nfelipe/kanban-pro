# =============================================================
#  KANBAN PRO — Environment Variables (Root / Docker Compose)
#  Copy this file to .env and fill in your values.
#  cp .env.example .env
# =============================================================

# ─── DATABASE ─────────────────────────────────────────────────
# Full connection string used by Prisma and Docker Compose
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/kanban_db?schema=public"

# Individual credentials used by the postgres Docker service
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=kanban_db

# ─── BACKEND ──────────────────────────────────────────────────
# Port the Express API will listen on
PORT=3001

# Secret key for signing JWT tokens — use a long random string in production
# Generate one: openssl rand -hex 64
JWT_SECRET=replace_with_a_long_random_secret

# Token expiry duration (e.g. 7d, 24h, 60m)
JWT_EXPIRES_IN=7d

# Allowed CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:3000

# Node environment: development | production | test
NODE_ENV=development

# ─── FRONTEND ─────────────────────────────────────────────────
# Public API base URL consumed by Next.js (must start with NEXT_PUBLIC_)
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket server URL for real-time collaboration
NEXT_PUBLIC_WS_URL=http://localhost:3001
